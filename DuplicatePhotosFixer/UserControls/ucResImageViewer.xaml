<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucResImageViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <ItemsControl x:Name="groupsItemsControl" 
                  ItemsSource="{Binding DuplicateGroups}"
                  Background="Transparent">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <!-- Each Duplicate Group -->
                <Border Background="{DynamicResource bgrclr_whitish}" 
                        BorderBrush="{DynamicResource clr_grayborder}" 
                        BorderThickness="1" 
                        Margin="10"
                        CornerRadius="2">
                    <StackPanel>
                        <!-- Group Header -->
                        <Border Background="{DynamicResource bgclr_dark}" 
                                BorderBrush="{DynamicResource clr_darkborder}" 
                                BorderThickness="0 0 0 1"
                                Padding="10 8">
                            <DockPanel>
                                <TextBlock Text="{Binding GroupName}" 
                                           FontWeight="SemiBold" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource cl_fg_primary}"/>
                                <TextBlock DockPanel.Dock="Right"
                                           FontSize="14"
                                           Foreground="{DynamicResource cl_fg_primary}">
                                    <Run Text="|"/>
                                    <Run Text="{Binding PhotoCount, Mode=OneWay}"/>
                                    <Run Text="Photos"/>
                                </TextBlock>
                            </DockPanel>
                        </Border>

                        <!-- Photos Grid -->
                        <ItemsControl ItemsSource="{Binding Photos}" 
                                      Margin="10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Individual Photo Card -->
                                    <Border Background="White" 
                                            BorderBrush="{DynamicResource clr_grayborder}" 
                                            BorderThickness="1" 
                                            Width="280" 
                                            Height="350"
                                            Margin="5"
                                            CornerRadius="2"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource frg_clr_blue}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="250"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Image Preview -->
                                            <Border Grid.Row="0" 
                                                    Background="#F5F5F5" 
                                                    BorderBrush="{DynamicResource clr_grayborder}" 
                                                    BorderThickness="0 0 0 1">
                                                <Grid>
                                                    <Image x:Name="imgPreview"
                                                           Source="{Binding ThumbnailPath}" 
                                                           Stretch="Uniform"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           MaxHeight="240"
                                                           MaxWidth="270"/>

                                                    <!-- Fallback if no thumbnail -->
                                                    <TextBlock Text="No Preview" 
                                                               FontSize="14" 
                                                               Foreground="Gray"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Checkbox Overlay -->
                                                    <CheckBox IsChecked="{Binding IsMarkedForDeletion, Mode=TwoWay}"
                                                              Width="20" 
                                                              Height="20"
                                                              Margin="10"
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Top"
                                                              Background="White"/>
                                                </Grid>
                                            </Border>

                                            <!-- File Info -->
                                            <StackPanel Grid.Row="1" 
                                                        Margin="10 8"
                                                        Background="White">
                                                <!-- File Name -->
                                                <TextBlock Text="{Binding fileName}" 
                                                           FontSize="13" 
                                                           FontWeight="SemiBold"
                                                           Foreground="#262626"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding fileName}"/>

                                                <!-- Date and Size -->
                                                <DockPanel Margin="0 5 0 0">
                                                    <TextBlock Text="{Binding ModifiedDate, StringFormat='MMM dd, yyyy'}" 
                                                               FontSize="12" 
                                                               Foreground="Gray"/>
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding FileSizeFormatted}" 
                                                               FontSize="12" 
                                                               Foreground="Gray"
                                                               HorizontalAlignment="Right"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
